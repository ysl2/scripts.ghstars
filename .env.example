# Optional in all modes. If empty, GitHub API falls back to the unauthenticated rate limit.
GITHUB_TOKEN=

# Optional for repo discovery from arXiv papers. If empty, HF exact discovery is unavailable.
HUGGINGFACE_TOKEN=

# Optional in CSV / URL / Notion modes. Default: retry a cached no-repo paper after 7 days.
HF_EXACT_NO_REPO_RECHECK_DAYS=7

# Required only for Notion mode.
NOTION_TOKEN=
DATABASE_ID=
